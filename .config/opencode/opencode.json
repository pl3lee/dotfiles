{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "edit": "allow",
        "bash": {
            "git commit": "deny",
            "git push": "deny",
            "*": "allow"
        },
        "webfetch": "allow",
        "skill": "allow",
        "question": "allow"
    },
    "agent": {
        "plan": {
            "mode": "primary",
            "permission": {
                "edit": {
                    "*": "deny",
                    "plans/*": "allow"
                }
            }
        },
    },
    "autoshare": false,
    "autoupdate": true,
    "provider": {
        "openai": {
            "models": {
                "gpt-5.1-codex-max": {
                    "options": {
                        "store": false,
                    }
                },
                "gpt-5.2-codex": {
                    "options": {
                        "store": false,
                    }
                },
            }
        },
        "github-copilot": {
            "models": {
                "claude-opus-4.5": {
                    "options": {
                        "store": false,
                        "include": [
                            "reasoning.encrypted_content"
                        ]
                    }
                }
            }
        },
        "litellm": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LiteLLM",
            "options": {
                "baseURL": "{env:LITELLM_BASE_URL}/v1",
            },
            "models": {
                "us.anthropic.claude-opus-4-5-20251101-v1:0": {
                    "name": "Claude Opus 4.5",
                    "limit": {
                        "context": 200000,
                        "output": 64000
                    }
                },
                "us.anthropic.claude-sonnet-4-5-20250929-v1:0": {
                    "name": "Claude Sonnet 4.5",
                    "limit": {
                        "context": 200000,
                        "output": 64000
                    }
                }
            }
        }
    },
    "mcp": {
        "GitHub": {
            "type": "remote",
            "url": "https://api.githubcopilot.com/mcp/",
            "enabled": true,
            "headers": {
                "Authorization": "Bearer {env:GITHUB_TOKEN}"
            }
        },
        "Atlassian": {
            "type": "remote",
            "url": "https://mcp.atlassian.com/v1/mcp",
            "enabled": true,
        },
    }
}
